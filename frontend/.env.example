# ============================================================================
# HAYOSS FRONTEND - Environment Variables
# ============================================================================

# Backend API URL (for admin proxy and API calls)
# The backend runs on port 5000 by default
BACKEND_URL=http://localhost:5000

# Next.js public environment variables
# API URL for frontend to call backend
NEXT_PUBLIC_API_URL=http://localhost:5000
# Frontend URL (used for SEO and canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# NEXTAUTH.JS - Authentication
# ============================================================================
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=your-super-secret-auth-key-generate-with-openssl

# NextAuth URL (production domain)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Provider (optional)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
