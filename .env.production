# ============================================================================
# HAYOSS.COM - Production Environment Variables
# ============================================================================
# Backend API: https://api.hayoss.com
# Frontend: https://www.hayoss.com
# ============================================================================
# IMPORTANT: Ne jamais commiter ce fichier avec de vraies valeurs !
# Utilisez les secrets de votre plateforme d'hébergement (Railway, Render, etc.)
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=production
PORT=5000
API_BASE_URL=https://api.hayoss.com
FRONTEND_URL=https://www.hayoss.com

# ============================================================================
# CORS - Origines autorisées
# ============================================================================
CORS_ORIGIN=https://www.hayoss.com,https://hayoss.com

# ============================================================================
# DATABASE - PostgreSQL (Supabase, Neon, Railway, etc.)
# ============================================================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/hayoss_prod?sslmode=require
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require

# ============================================================================
# REDIS / CACHE (Upstash)
# ============================================================================
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_HOST.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REST_TOKEN

# ============================================================================
# SECURITY
# ============================================================================
# Clé de chiffrement pour les tokens OAuth AliExpress (générer avec: openssl rand -hex 32)
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32

# JWT Secret pour l'authentification (générer avec: openssl rand -base64 32)
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_32
JWT_EXPIRES_IN=7d

# ============================================================================
# HYP (YaadPay) - Passerelle de Paiement Israélienne
# ============================================================================
HYP_MASOF=YOUR_HYP_MASOF_NUMBER
HYP_PASSP=YOUR_HYP_PASSWORD
HYP_API_SIGNATURE_KEY=YOUR_HYP_SIGNATURE_KEY

# URLs de callback Hyp (remplacez par votre domaine)
HYP_SUCCESS_URL=https://www.hayoss.com/checkout/success
HYP_ERROR_URL=https://www.hayoss.com/checkout/error
HYP_NOTIFY_URL=https://api.hayoss.com/api/v1/webhooks/hyp

# Mode Sandbox pour les tests (mettre false en production)
HYP_SANDBOX=false

# ============================================================================
# ALIEXPRESS - Open Platform DS (Dropshipping Solution)
# ============================================================================
# Obtenez ces clés depuis: https://open.aliexpress.com/
ALIEXPRESS_APP_KEY=YOUR_ALIEXPRESS_APP_KEY
ALIEXPRESS_APP_SECRET=YOUR_ALIEXPRESS_APP_SECRET

# URL de callback OAuth AliExpress (doit être whitelistée dans le Dev Center)
ALIEXPRESS_CALLBACK_URL=https://api.hayoss.com/api/aliexpress/callback

# Tracking ID pour l'affiliation (optionnel)
ALIEXPRESS_TRACKING_ID=YOUR_TRACKING_ID

# Token d'accès initial (sera rafraîchi automatiquement via OAuth)
ALIEXPRESS_ACCESS_TOKEN=

# ============================================================================
# OPENAI - GPT-4 pour les traductions luxe
# ============================================================================
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# ============================================================================
# RESEND - Service d'envoi d'emails transactionnels
# ============================================================================
# Obtenez une clé API sur: https://resend.com/
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# Configuration email
EMAIL_FROM=contact@hayoss.com
EMAIL_FROM_NAME=Hayoss
EMAIL_REPLY_TO=contact@hayoss.com

# ============================================================================
# META (Facebook) - Conversions API pour le tracking server-side
# ============================================================================
# Pixel ID depuis Events Manager: https://business.facebook.com/events_manager
META_PIXEL_ID=YOUR_META_PIXEL_ID

# Access Token CAPI (générer depuis Events Manager > Settings > Generate Access Token)
META_CAPI_ACCESS_TOKEN=YOUR_META_CAPI_ACCESS_TOKEN

# Code de test (uniquement pour le développement, supprimer en prod)
# META_TEST_EVENT_CODE=TEST12345

# ============================================================================
# GOOGLE ANALYTICS (optionnel)
# ============================================================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX

# ============================================================================
# SENTRY - Monitoring d'erreurs (recommandé)
# ============================================================================
SENTRY_DSN=https://YOUR_SENTRY_KEY@o123456.ingest.sentry.io/123456
SENTRY_ENVIRONMENT=production

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Rate Limits spécifiques
API_RATE_LIMIT_PRODUCTS=50
API_RATE_LIMIT_ORDERS=20
API_RATE_LIMIT_WEBHOOKS=100

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOGS_DIR=/var/log/hayoss

# ============================================================================
# CRON JOBS
# ============================================================================
# Synchronisation des stocks AliExpress (toutes les 6 heures)
STOCK_SYNC_CRON=0 */6 * * *

# Synchronisation des tracking (toutes les 4 heures)
TRACKING_SYNC_CRON=0 */4 * * *

# Nettoyage des données obsolètes (quotidien à 3h)
DATA_CLEANUP_CRON=0 3 * * *

# Import automatique de produits (hebdomadaire, lundi 2h)
PRODUCT_IMPORT_CRON=0 2 * * 1

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_PRODUCT_IMPORT=true
ENABLE_TRACKING_SYNC=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_META_CAPI=true

# ============================================================================
# ADMIN
# ============================================================================
ADMIN_EMAIL=admin@hayoss.com
ADMIN_API_KEY=GENERATE_SECURE_ADMIN_KEY

# ============================================================================
# CHECKLIST AVANT DÉPLOIEMENT
# ============================================================================
# [ ] Toutes les variables sont remplies avec des valeurs de production
# [ ] DATABASE_URL pointe vers une base PostgreSQL hébergée (pas localhost)
# [ ] REDIS_URL utilise une connexion SSL (rediss://)
# [ ] HYP_SANDBOX=false
# [ ] ALIEXPRESS_CALLBACK_URL est whitelisté dans le Dev Center
# [ ] Domaine vérifié dans Resend pour l'envoi d'emails
# [ ] META_PIXEL_ID configuré dans Events Manager
# [ ] SENTRY_DSN configuré pour le monitoring
# [ ] CORS_ORIGIN contient uniquement les domaines autorisés
# [ ] Secrets générés avec openssl (ENCRYPTION_KEY, JWT_SECRET)
# ============================================================================
