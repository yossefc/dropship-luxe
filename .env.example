# ============================================================================
# DROPSHIP LUXE - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control!
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/dropship_luxe?schema=public

# ============================================================================
# REDIS (For BullMQ queues and caching)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# HYP (YAADPAY) - PAYMENT GATEWAY
# ============================================================================
# These credentials are obtained from your Hyp/YaadPay merchant account
# Documentation: https://yaadpay.docs.apiary.io/
#
# IMPORTANT: Stripe has been completely removed from this project.
# All payments are now processed through Hyp (YaadPay).

# HYP_MASOF - Terminal ID (Numéro de terminal)
# This is your merchant identification number provided by YaadPay
# Example: 0010070211
HYP_MASOF=your_terminal_id

# HYP_PASSP - Terminal Password (Mot de passe du terminal)
# Authentication password for your terminal - used for API calls
HYP_PASSP=your_terminal_password

# HYP_API_SIGNATURE_KEY - HMAC Signature Key
# Used to generate HMAC-SHA256 signatures for webhook validation
# This ensures webhook authenticity and prevents tampering
# Provided by YaadPay in your merchant dashboard
HYP_API_SIGNATURE_KEY=your_32_char_signature_key_here

# HYP_PAGEMODEL - Payment Page Model
# Controls how the payment page is displayed:
# 0 = Full page redirect (recommended for first integration)
# 1 = Iframe embedded
# 2 = API mode (for custom integration)
HYP_PAGEMODEL=0

# Callback URLs - HTTPS required in production
HYP_SUCCESS_URL=https://your-domain.com/payment/success
HYP_ERROR_URL=https://your-domain.com/payment/error
HYP_NOTIFY_URL=https://your-domain.com/webhooks/hyp

# ============================================================================
# ALIEXPRESS OPEN PLATFORM (Dropshipping Solution)
# ============================================================================
# Register your app at: https://openservice.aliexpress.com/
# Required permissions: DS Center (Dropshipping Solution APIs)

# App Key - Your application identifier
ALIEXPRESS_APP_KEY=your_app_key

# App Secret - Keep this secret! Used for API signatures
ALIEXPRESS_APP_SECRET=your_app_secret

# Access Token - Obtained via OAuth flow (/api/aliexpress/authorize)
# Leave empty initially - stored in database after OAuth completion
ALIEXPRESS_ACCESS_TOKEN=

# Tracking ID - For affiliate commission tracking (optional)
ALIEXPRESS_TRACKING_ID=your_tracking_id

# OAuth Callback URL - Must match your app configuration
ALIEXPRESS_CALLBACK_URL=https://your-domain.com/api/aliexpress/callback

# ============================================================================
# OPENAI (AI-Powered Product Translations)
# ============================================================================
# Get your API key at: https://platform.openai.com/api-keys
# Used for:
# - Luxury copywriting for product descriptions
# - Multi-language translations (FR, EN, ES, IT, DE)
# - SEO-optimized meta content
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# SECURITY
# ============================================================================

# ENCRYPTION_KEY - AES-256 encryption for sensitive data
# Used to encrypt AliExpress OAuth tokens at rest
# Generate with: openssl rand -hex 32
# MUST be exactly 64 hex characters (256-bit key)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# JWT_SECRET - For API authentication tokens
# Generate with: openssl rand -base64 32
# Minimum 32 characters required
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_IN=24h

# ADMIN_PASSWORD - Dashboard protection
# Used for Bearer token authentication on /api/admin/* endpoints
ADMIN_PASSWORD=your_secure_admin_password

# ============================================================================
# CORS & RATE LIMITING
# ============================================================================
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=365
LOGS_DIR=./logs

# ============================================================================
# CRON SCHEDULES (Standard cron format)
# ============================================================================
# Stock synchronization with AliExpress (default: every 6 hours)
CRON_STOCK_SYNC=0 */6 * * *

# Old data cleanup (default: daily at midnight)
CRON_DATA_CLEANUP=0 0 * * *

# ============================================================================
# BUSINESS RULES - Product Import Filtering
# ============================================================================
# Minimum seller rating to consider (0-5 scale)
MIN_PRODUCT_RATING=4.5

# Minimum order volume (sales count)
MIN_ORDER_VOLUME=100

# Minimum profit margin (0-1 scale, 0.30 = 30%)
MIN_PROFIT_MARGIN=0.30

# ============================================================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@dropship-luxe.com
SMTP_FROM_NAME=Dropship Luxe

# ============================================================================
# META CONVERSIONS API (CAPI) - Server-Side Ad Tracking
# ============================================================================
# Set up at: https://business.facebook.com/events_manager
# Documentation: https://developers.facebook.com/docs/marketing-api/conversions-api
#
# Benefits of CAPI:
# - Bypasses ad blockers
# - More reliable conversion tracking
# - Better ad optimization
# - Required for iOS 14+ tracking

# Meta Pixel ID - Found in Events Manager
META_PIXEL_ID=your_pixel_id

# Conversions API Access Token
# Generate at: Events Manager > Settings > Conversions API > Generate Access Token
META_CAPI_ACCESS_TOKEN=your_capi_access_token

# Test Event Code (optional) - For testing events in Events Manager
# Remove in production! Only use during setup and debugging
# META_TEST_EVENT_CODE=TEST12345

# ============================================================================
# RESEND - Transactional Emails
# ============================================================================
# Get your API key at: https://resend.com/api-keys
# Used for order confirmations, shipping updates, etc.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=commandes@hayoss.com
RESEND_FROM_NAME=Hayoss

# ============================================================================
# DEVELOPMENT / DEBUGGING (Disable in production!)
# ============================================================================
DEBUG_ALIEXPRESS=false
DEBUG_WEBHOOKS=false
