# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/dropship_luxe?schema=public

# ===========================================
# REDIS (Queue & Cache)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# STRIPE (PCI-DSS Compliant)
# ===========================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ===========================================
# ALIEXPRESS API
# ===========================================
ALIEXPRESS_APP_KEY=xxxxxxxxxxxxx
ALIEXPRESS_APP_SECRET=xxxxxxxxxxxxx
ALIEXPRESS_ACCESS_TOKEN=xxxxxxxxxxxxx
ALIEXPRESS_TRACKING_ID=xxxxxxxxxxxxx

# ===========================================
# OPENAI (Description Rewriting)
# ===========================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# ===========================================
# SECURITY
# ===========================================
# AES-256 encryption key (32 bytes hex)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# JWT Secret for admin authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h

# ===========================================
# CORS & RATE LIMITING
# ===========================================
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=365
LOGS_DIR=./logs

# ===========================================
# CRON SCHEDULES
# ===========================================
CRON_STOCK_SYNC=0 */6 * * *
CRON_DATA_CLEANUP=0 0 * * *

# ===========================================
# PRODUCT FILTERING THRESHOLDS
# ===========================================
MIN_PRODUCT_RATING=4.5
MIN_ORDER_VOLUME=100
MIN_PROFIT_MARGIN=0.30
