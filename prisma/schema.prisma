generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id                String    @id @default(uuid())
  email             String    @unique
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  phone             String?
  stripeCustomerId  String?   @unique @map("stripe_customer_id")
  isVerified        Boolean   @default(false) @map("is_verified")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  addresses         Address[]
  orders            Order[]

  @@map("customers")
}

model Address {
  id              String    @id @default(uuid())
  customerId      String    @map("customer_id")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  street          String
  city            String
  postalCode      String    @map("postal_code")
  country         String
  phone           String?
  isDefault       Boolean   @default(false) @map("is_default")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model Product {
  id                  String    @id @default(uuid())
  aliexpressId        String    @unique @map("aliexpress_id")
  aliexpressUrl       String?   @map("aliexpress_url")
  sku                 String?   @unique
  // Base name kept for internal reference / fallback
  name                String?
  // Original content from supplier (before AI rewriting)
  originalName        String?   @map("original_name") @db.Text
  originalDescription String?   @map("original_description") @db.Text
  categoryId          String?   @map("category_id")
  images              String[]
  // Pricing
  basePrice           Decimal   @map("base_price") @db.Decimal(10, 2)
  costPrice           Decimal   @map("cost_price") @db.Decimal(10, 2)
  sellingPrice        Decimal   @map("selling_price") @db.Decimal(10, 2)
  currency            String    @default("EUR")
  // Physical properties
  weight              Decimal?  @db.Decimal(6, 3) // kg
  dimensions          Json?     // { length, width, height }
  // Metrics
  stock               Int       @default(0)
  rating              Decimal?  @db.Decimal(2, 1)
  orderVolume         Int       @default(0) @map("order_volume")
  // Supplier info
  supplierId          String    @map("supplier_id")
  supplierName        String    @map("supplier_name")
  shippingTimeMin     Int?      @map("shipping_time_min")
  shippingTimeMax     Int?      @map("shipping_time_max")
  // Import scoring
  importScore         Int?      @map("import_score")
  importScoreBreakdown Json?    @map("import_score_breakdown")
  riskFactors         String[]  @map("risk_factors")
  // Status flags
  isActive            Boolean   @default(true) @map("is_active")
  isFeatured          Boolean   @default(false) @map("is_featured")
  // Timestamps
  lastSyncAt          DateTime? @map("last_sync_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  category            Category? @relation(fields: [categoryId], references: [id])
  translations        ProductTranslation[]
  variants            ProductVariant[]
  orderItems          OrderItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([importScore])
  @@index([lastSyncAt])
  @@map("products")
}

// ============================================================================
// Product Translations - Multi-language support
// ============================================================================
// Stores SEO-optimized, AI-generated luxury copywriting for each locale
// ============================================================================

model ProductTranslation {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  locale          String   // "fr", "en", "es", "it", "de"

  // Core content - AI-rewritten luxury copywriting
  name            String
  slug            String   // URL-friendly, locale-specific
  description     String   @db.Text
  descriptionHtml String   @map("description_html") @db.Text

  // Product details
  benefits        String[] // Key benefits/selling points
  ingredients     String?  @db.Text
  howToUse        String?  @map("how_to_use") @db.Text

  // SEO metadata - optimized for each market
  metaTitle       String   @map("meta_title")
  metaDescription String   @map("meta_description")
  metaKeywords    String[] @map("meta_keywords")

  // AI generation metadata
  aiModel         String?  @map("ai_model") // e.g., "gpt-4-turbo"
  aiPromptVersion String?  @map("ai_prompt_version") // For tracking prompt iterations
  generatedAt     DateTime @default(now()) @map("generated_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
  @@index([locale, slug])
  @@map("product_translations")
}

model ProductVariant {
  id              String    @id @default(uuid())
  productId       String    @map("product_id")
  aliexpressSku   String?   @map("aliexpress_sku")
  name            String    // Base name (internal reference)
  sku             String?   @unique
  price           Decimal   @db.Decimal(10, 2)
  currency        String    @default("EUR")
  stock           Int       @default(0)
  attributes      Json      @default("{}")
  image           String?
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  translations    ProductVariantTranslation[]

  @@index([productId])
  @@index([isActive])
  @@map("product_variants")
}

// ============================================================================
// Product Variant Translations
// ============================================================================

model ProductVariantTranslation {
  id          String   @id @default(uuid())
  variantId   String   @map("variant_id")
  locale      String

  name        String   // Translated variant name (e.g., "Rose Gold", "Or Rose")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, locale])
  @@index([locale])
  @@map("product_variant_translations")
}

// ============================================================================
// Category with Translations
// ============================================================================

model Category {
  id            String    @id @default(uuid())
  aliexpressId  String?   @unique @map("aliexpress_id")
  name          String    // Base name for internal reference
  slug          String    @unique // Internal identifier
  parentId      String?   @map("parent_id")
  sortOrder     Int       @default(0) @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  parent       Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryHierarchy")
  translations CategoryTranslation[]
  products     Product[]

  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model CategoryTranslation {
  id              String   @id @default(uuid())
  categoryId      String   @map("category_id")
  locale          String

  name            String
  slug            String   // URL-friendly, locale-specific
  description     String?  @db.Text

  // SEO
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@map("category_translations")
}

model Order {
  id                    String        @id @default(uuid())
  orderNumber           String        @unique @map("order_number")
  customerId            String        @map("customer_id")
  customerEmail         String        @map("customer_email")

  // Shipping Address
  shippingFirstName     String        @map("shipping_first_name")
  shippingLastName      String        @map("shipping_last_name")
  shippingStreet        String        @map("shipping_street")
  shippingCity          String        @map("shipping_city")
  shippingPostalCode    String        @map("shipping_postal_code")
  shippingCountry       String        @map("shipping_country")
  shippingPhone         String?       @map("shipping_phone")

  // Billing Address
  billingFirstName      String        @map("billing_first_name")
  billingLastName       String        @map("billing_last_name")
  billingStreet         String        @map("billing_street")
  billingCity           String        @map("billing_city")
  billingPostalCode     String        @map("billing_postal_code")
  billingCountry        String        @map("billing_country")
  billingPhone          String?       @map("billing_phone")

  // Amounts
  subtotal              Decimal       @db.Decimal(10, 2)
  shippingCost          Decimal       @map("shipping_cost") @db.Decimal(10, 2)
  tax                   Decimal       @db.Decimal(10, 2)
  total                 Decimal       @db.Decimal(10, 2)
  currency              String        @default("EUR")

  // Status
  status                OrderStatus   @default(pending)
  paymentStatus         PaymentStatus @default(pending) @map("payment_status")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")

  // Supplier Orders
  aliexpressOrderIds    String[]      @map("aliexpress_order_ids")
  trackingNumbers       String[]      @map("tracking_numbers")

  notes                 String?       @db.Text

  // Timestamps
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  paidAt                DateTime?     @map("paid_at")
  shippedAt             DateTime?     @map("shipped_at")
  deliveredAt           DateTime?     @map("delivered_at")

  customer              Customer      @relation(fields: [customerId], references: [id])
  items                 OrderItem[]

  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(uuid())
  orderId       String    @map("order_id")
  productId     String    @map("product_id")
  productName   String    @map("product_name")
  sku           String
  quantity      Int
  unitPrice     Decimal   @map("unit_price") @db.Decimal(10, 2)
  supplierPrice Decimal   @map("supplier_price") @db.Decimal(10, 2)
  currency      String    @default("EUR")
  variantId     String?   @map("variant_id")
  variantName   String?   @map("variant_name")
  createdAt     DateTime  @default(now()) @map("created_at")

  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  action      String
  entity      String
  entityId    String?   @map("entity_id")
  changes     Json?
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  processing
  succeeded
  failed
  cancelled
  refunded
}

// ============================================================================
// Import History - Tracks automated product imports
// ============================================================================

model ImportHistory {
  id                String    @id @default(uuid())
  jobId             String    @map("job_id")
  jobName           String    @map("job_name")
  keywords          String[]

  // Statistics
  totalProcessed    Int       @map("total_processed")
  importedCount     Int       @map("imported_count")
  quarantinedCount  Int       @map("quarantined_count")
  rejectedCount     Int       @map("rejected_count")
  errorCount        Int       @map("error_count")
  averageScore      Int       @map("average_score")
  processingTimeMs  Int       @map("processing_time_ms")

  // Details
  importedProducts  String[]  @map("imported_products") // AliExpress IDs
  errors            Json[]    // Array of { productId, stage, message }

  // Timestamps
  startedAt         DateTime  @map("started_at")
  completedAt       DateTime  @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([jobId])
  @@index([createdAt])
  @@map("import_history")
}

// ============================================================================
// Product Quarantine - Products pending review
// ============================================================================

model ProductQuarantine {
  id              String    @id @default(uuid())
  aliexpressId    String    @unique @map("aliexpress_id")
  title           String
  score           Int
  reason          String
  productData     Json      @map("product_data")
  shippingCost    Decimal   @map("shipping_cost") @db.Decimal(10, 2)
  suggestedPrice  Decimal   @map("suggested_price") @db.Decimal(10, 2)
  scoreBreakdown  Json      @map("score_breakdown")
  riskFactors     String[]  @map("risk_factors")

  // Review status
  status          QuarantineStatus @default(pending)
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewNotes     String?   @map("review_notes") @db.Text

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([score])
  @@index([createdAt])
  @@map("product_quarantine")
}

enum QuarantineStatus {
  pending
  approved
  rejected
  needs_review
}
