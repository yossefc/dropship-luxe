{
  "name": "dropship-luxe",
  "version": "1.0.0",
  "description": "Plateforme e-commerce haut de gamme avec dropshipping AliExpress",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:prod": "docker-compose up -d"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "express": "^4.18.2",
    "stripe": "^14.18.0",
    "ioredis": "^5.3.2",
    "bullmq": "^5.4.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "crypto-js": "^4.2.0",
    "axios": "^1.6.7",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.5",
    "openai": "^4.28.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.20",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/crypto-js": "^4.2.2",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "prisma": "^5.10.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
